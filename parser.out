    NEQ             reduce using rule 46 (Primary -> ( Expression ) .)
    AND             reduce using rule 46 (Primary -> ( Expression ) .)
    ;               reduce using rule 46 (Primary -> ( Expression ) .)
    OR              reduce using rule 46 (Primary -> ( Expression ) .)
    )               reduce using rule 46 (Primary -> ( Expression ) .)


state 82

    (18) IfStatement -> IF ( Expression ) Statement .
    (19) IfStatement -> IF ( Expression ) Statement . ELSE Statement

    }               reduce using rule 18 (IfStatement -> IF ( Expression ) Statement .)
    ;               reduce using rule 18 (IfStatement -> IF ( Expression ) Statement .)
    {               reduce using rule 18 (IfStatement -> IF ( Expression ) Statement .)
    ID              reduce using rule 18 (IfStatement -> IF ( Expression ) Statement .)
    IF              reduce using rule 18 (IfStatement -> IF ( Expression ) Statement .)
    WHILE           reduce using rule 18 (IfStatement -> IF ( Expression ) Statement .)
    ELSE            shift and go to state 84

  ! ELSE            [ reduce using rule 18 (IfStatement -> IF ( Expression ) Statement .) ]


state 83

    (20) WhileStatement -> WHILE ( Expression ) Statement .

    }               reduce using rule 20 (WhileStatement -> WHILE ( Expression ) Statement .)
    ;               reduce using rule 20 (WhileStatement -> WHILE ( Expression ) Statement .)
    {               reduce using rule 20 (WhileStatement -> WHILE ( Expression ) Statement .)
    ID              reduce using rule 20 (WhileStatement -> WHILE ( Expression ) Statement .)
    IF              reduce using rule 20 (WhileStatement -> WHILE ( Expression ) Statement .)
    WHILE           reduce using rule 20 (WhileStatement -> WHILE ( Expression ) Statement .)
    ELSE            reduce using rule 20 (WhileStatement -> WHILE ( Expression ) Statement .)


state 84

    (19) IfStatement -> IF ( Expression ) Statement ELSE . Statement
    (11) Statement -> . ;
    (12) Statement -> . Block
    (13) Statement -> . Assignment
    (14) Statement -> . IfStatement
    (15) Statement -> . WhileStatement
    (16) Block -> . { Statements }
    (17) Assignment -> . ID = Expression ;
    (18) IfStatement -> . IF ( Expression ) Statement
    (19) IfStatement -> . IF ( Expression ) Statement ELSE Statement
    (20) WhileStatement -> . WHILE ( Expression ) Statement

    ;               shift and go to state 18
    {               shift and go to state 15
    ID              shift and go to state 23
    IF              shift and go to state 24
    WHILE           shift and go to state 25

    Statement                      shift and go to state 85
    Block                          shift and go to state 19
    Assignment                     shift and go to state 20
    IfStatement                    shift and go to state 21
    WhileStatement                 shift and go to state 22

state 85

    (19) IfStatement -> IF ( Expression ) Statement ELSE Statement .

    }               reduce using rule 19 (IfStatement -> IF ( Expression ) Statement ELSE Statement .)
